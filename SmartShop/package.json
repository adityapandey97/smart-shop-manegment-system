{
  "name": "smart-shop-management",
  "version": "1.0.0",
  "description": "Smart Shop Management System with Udhar Tracking, Dynamic Pricing, Inventory Prediction, and Profit Analysis",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm run build --prefix client",
    "install-all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.4.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.4",
    "razorpay": "^2.9.0",
    "twilio": "^4.15.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "keywords": ["mern", "shop", "management", "udhar", "inventory"],
  "author": "SmartShop Team",
  "license": "MIT"
}
