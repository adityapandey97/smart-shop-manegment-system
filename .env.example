# ============================================
#   SmartShop .env - Environment Variables
#   Copy this file to .env and fill in values
# ============================================

# --- Server Settings ---
PORT=5000
NODE_ENV=development

# --- MongoDB Database ---
# Get this from MongoDB Atlas (cloud) or use local MongoDB
MONGO_URI=mongodb+srv://your_username:your_password@cluster0.mongodb.net/smartshop?retryWrites=true&w=majority

# --- JWT Secret (make it long and random for security) ---
JWT_SECRET=your_super_secret_jwt_key_make_it_very_long_and_random_123456

# --- Razorpay Payment Gateway ---
# Get these from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# --- Cloudinary (for product image uploads) ---
# Get these from https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email Notifications (Gmail SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# --- Twilio WhatsApp (optional - for udhar reminders) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Frontend URL (used for CORS) ---
CLIENT_URL=http://localhost:3000
